{
  "name": "@tiaohsun/vue-datepicker",
  "version": "1.0.5",
  "description": "A Vue 3 datepicker with multi-calendar support, styled with Tailwind CSS",
  "license": "MIT",
  "author": {
    "name": "tiaohsun",
    "email": "tiaohsun@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tiaohsun31/vue-datepicker.git",
    "directory": "packages/vue-datepicker"
  },
  "bugs": {
    "url": "https://github.com/Tiaohsun31/vue-datepicker/issues"
  },
  "homepage": "https://vue-datepicker.tiaohsun.dev",
  "keywords": [
    "vue",
    "vue3",
    "datepicker",
    "calendar",
    "typescript",
    "tailwindcss",
    "internationalization",
    "i18n",
    "date-picker",
    "date-range",
    "components"
  ],
  "type": "module",
  "main": "./dist/vue-datepicker.umd.js",
  "module": "./dist/vue-datepicker.es.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/vue-datepicker.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-datepicker.es.js",
      "require": "./dist/vue-datepicker.umd.js"
    },
    "./style": {
      "types": "./dist/vue-datepicker.css.d.ts",
      "default": "./dist/vue-datepicker.css"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only && pnpm run build:types",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build-only",
    "test:unit": "vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:coverage": "vitest --coverage"
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": false
    },
    "vue": {
      "optional": false
    }
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "dayjs": "^1.11.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "^1.70.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxlint": "^1.70.0",
    "prettier": "3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
