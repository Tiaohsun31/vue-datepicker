{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*", "src/**/*.vue"],
  "exclude": [
    "src/**/__tests__/*",
    "src/**/*.test.*",
    "src/**/*.spec.*",
    "**/*.stories.*",
    "**/*.md",
    "playground/**/*"
  ],
  "compilerOptions": {
    // 不再使用 baseUrl（TS 6 已棄用）。moduleResolution: bundler 下
    // paths 直接相對於本 tsconfig 解析，毋需 baseUrl。
    "paths": {
      "@/*": ["./src/*"]
    },

    // 輸出配置
    "outDir": "./dist",
    "rootDir": "./src",

    // 模組系統
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",

    // 類型定義生成
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,

    // 嚴格模式
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": true,

    // Vue 相關
    "jsx": "preserve",
    "jsxImportSource": "vue",

    // 庫相關設置
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,

    // 類型檢查
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo"
  }
}
